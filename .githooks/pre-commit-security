#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
Git Pre-commit Hook - 安全扫描

功能:
- 检测暂存区 (staged) 文件中的硬编码敏感信息
- 检测本地用户路径暴露 (Linux/macOS/Windows)
- 检测文档文件中的绝对路径
- 阻止提交包含 token、API key、channel ID 等的代码

扫描范围:
- 代码文件：.py, .js, .ts, .json, .yaml, .yml
- 文档文件：.md, .rst, .txt (额外检查路径暴露)

安装:
    cp .githooks/pre-commit-security .git/hooks/pre-commit
    chmod +x .git/hooks/pre-commit

注意:
- 此 hook 仅扫描 staged 的文件
- 如果发现敏感信息，提交将被阻止
- ~/.env 是允许的正确形式
"""

import subprocess
import sys
import os
from pathlib import Path

# 扫描模式定义
SCAN_PATTERNS = {
    "github_token": {
        "pattern": r"ghp_[a-zA-Z0-9]{20,}",
        "message": "GitHub Personal Access Token",
        "severity": "HIGH"
    },
    "anthropic_key": {
        "pattern": r"sk-ant-[a-zA-Z0-9_-]{20,}",
        "message": "Anthropic API Key",
        "severity": "HIGH"
    },
    "openai_key": {
        "pattern": r"sk-proj-[a-zA-Z0-9_-]{20,}|sk-[a-zA-Z0-9]{48}",
        "message": "OpenAI API Key",
        "severity": "HIGH"
    },
    "dashscope_key": {
        "pattern": r"dashscope[a-zA-Z0-9_-]{20,}",
        "message": "Dashscope API Key",
        "severity": "HIGH"
    },
    "feishu_channel": {
        "pattern": r"(ou_[a-zA-Z0-9_-]{10,}|chan_[a-zA-Z0-9_-]{10,}|open_chat_id[a-zA-Z0-9_-]{10,})",
        "message": "Feishu Channel ID",
        "severity": "MEDIUM"
    },
    "local_path_home": {
        "pattern": r"/home/[a-zA-Z0-9_-]+/",
        "message": "本地用户路径 (可能暴露用户名)",
        "severity": "MEDIUM"
    },
    "local_path_absOLUTE": {
        "pattern": r"/Users/[a-zA-Z0-9_-]+/",
        "message": "macOS 本地用户路径",
        "severity": "MEDIUM"
    },
    "local_path_windows": {
        "pattern": r"C:\\\\Users\\\\[a-zA-Z0-9_-]+\\\\",
        "message": "Windows 本地用户路径",
        "severity": "MEDIUM"
    },
}

# 文档文件中额外检查的模式
DOC_SCAN_PATTERNS = {
    "env_file_path": {
        "pattern": r"[a-zA-Z0-9/_-]+/\.env(?!\"\)|\')|~?/?[a-zA-Z0-9_-]+/\.env",
        "message": ".env 文件路径暴露 (应使用 ~/.env)",
        "severity": "MEDIUM"
    },
    "project_path_exposure": {
        "pattern": r"/home/[a-zA-Z0-9_-]+/[a-zA-Z0-9_/-]+/github-insight-agent",
        "message": "项目绝对路径暴露",
        "severity": "MEDIUM"
    },
}

# 文档文件扩展名
DOC_EXTENSIONS = (".md", ".rst", ".txt", ".rst")

# 允许的占位符模式
ALLOWED_PLACEHOLDERS = {
    "YOUR_GITHUB_TOKEN_HERE",
    "YOUR_API_KEY_HERE",
    "your_token_here",
    "your_api_key_here",
    "ghp_your",
    "sk-xxx",
    "xxx",
    "placeholder",
}


def get_staged_files():
    """获取暂存区文件列表"""
    result = subprocess.run(
        ["git", "diff", "--cached", "--name-only"],
        capture_output=True,
        text=True
    )
    return result.stdout.strip().split("\n") if result.stdout.strip() else []


def scan_file_content(content: str, file_path: str) -> list:
    """扫描文件内容"""
    import re
    findings = []

    # 判断是否为文档文件
    is_doc_file = file_path.endswith(DOC_EXTENSIONS)

    for line_num, line in enumerate(content.split("\n"), 1):
        # 跳过注释
        stripped = line.strip()
        if stripped.startswith("#") or stripped.startswith("//"):
            continue

        # 跳过包含允许占位符的行
        if any(ph.lower() in line.lower() for ph in ALLOWED_PLACEHOLDERS):
            continue

        # 跳过从环境变量读取的代码
        if "os.getenv" in line or "os.environ" in line or "config." in line:
            continue

        for pattern_name, config in SCAN_PATTERNS.items():
            if re.search(config["pattern"], line, re.IGNORECASE):
                # 对于本地路径，允许 ~/.env 这种形式
                if pattern_name == "local_path_home" and "~/.env" in line:
                    continue
                findings.append({
                    "file": file_path,
                    "line": line_num,
                    "pattern": pattern_name,
                    "message": config["message"],
                    "severity": config["severity"],
                    "content": line.strip()[:80]
                })

        # 文档文件额外检查
        if is_doc_file:
            for pattern_name, config in DOC_SCAN_PATTERNS.items():
                if re.search(config["pattern"], line, re.IGNORECASE):
                    # 允许 ~/.env 这种正确形式
                    if "~/.env" in line and pattern_name == "env_file_path":
                        continue
                    findings.append({
                        "file": file_path,
                        "line": line_num,
                        "pattern": pattern_name,
                        "message": config["message"],
                        "severity": config["severity"],
                        "content": line.strip()[:80]
                    })

    return findings


def main():
    """主函数"""
    print("=" * 60)
    print("  Git Pre-commit 安全扫描")
    print("=" * 60)

    # 获取暂存区文件
    staged_files = get_staged_files()

    if not staged_files:
        print("✅ 无暂存文件，跳过扫描")
        return 0

    print(f"扫描 {len(staged_files)} 个暂存文件...")
    print()

    all_findings = []

    for file_path in staged_files:
        # 跳过排除的目录
        if any(exclude in file_path for exclude in ["node_modules", "venv", ".env", "__pycache__"]):
            continue

        # 获取文件内容
        result = subprocess.run(
            ["git", "diff", "--cached", file_path],
            capture_output=True,
            text=True
        )

        if result.stdout:
            findings = scan_file_content(result.stdout, file_path)
            all_findings.extend(findings)

    if not all_findings:
        print("✅ 安全扫描通过 - 未发现硬编码的敏感信息")
        print()
        print("=" * 60)
        return 0

    # 输出结果
    print("❌ 发现硬编码的敏感信息，提交已阻止:")
    print("-" * 60)

    high_count = 0
    for finding in all_findings:
        if finding["severity"] == "HIGH":
            high_count += 1
        print(f"  [{finding['severity']}] {finding['message']}")
        print(f"    文件：{finding['file']}")
        print(f"    行：{finding['line']}")
        print(f"    内容：{finding['content']}")
        print()

    print("-" * 60)
    print(f"发现 {len(all_findings)} 个问题 (HIGH={high_count})")
    print()
    print("解决方法:")
    print("  1. 使用环境变量代替硬编码值")
    print("     例如：os.getenv('GITHUB_TOKEN')")
    print()
    print("  2. 将敏感信息添加到 ~/.env 文件 (不要使用绝对路径)")
    print()
    print("  3. 如果只是测试占位符，使用: YOUR_TOKEN_HERE")
    print("  4. 文档中使用 ~/ 或 <项目根目录> 代替绝对路径")
    print("     错误：/home/user/project")
    print("     正确：~/.env 或 <项目根目录>/configs/")
    print()
    print("=" * 60)

    # 如果有 HIGH 级别问题，阻止提交
    if high_count > 0:
        print("\n❌ 提交被阻止 - 请修复 HIGH 级别安全问题")
        return 1

    print("\n⚠️  警告 - 发现 MEDIUM 级别问题，但仍允许提交")
    return 0


if __name__ == "__main__":
    sys.exit(main())
