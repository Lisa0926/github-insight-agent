#!/bin/sh
# Git post-commit hook: Auto-update CHANGELOG.md after each commit
#
# Installation:
#   cp .githooks/post-commit .git/hooks/post-commit
#   chmod +x .git/hooks/post-commit

# Check if git-cliff is installed
if ! command -v git-cliff &> /dev/null; then
    exit 0
fi

# Generate unreleased changelog
git cliff --unreleased --output CHANGELOG.md.tmp 2>/dev/null || exit 0

if [ -f CHANGELOG.md.tmp ]; then
    # Preserve header (first 15 lines), append new content
    head -n 15 CHANGELOG.md > CHANGELOG.md.new
    tail -n +2 CHANGELOG.md.tmp >> CHANGELOG.md.new
    mv CHANGELOG.md.new CHANGELOG.md
    rm -f CHANGELOG.md.tmp

    # Only amend if changelog actually changed
    if ! git diff --quiet --exit-code CHANGELOG.md 2>/dev/null; then
        git add CHANGELOG.md
        git commit --amend --no-verify -C HEAD 2>/dev/null
    fi
fi
