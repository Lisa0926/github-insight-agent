#!/bin/sh
# Git commit-msg hook: Validate commit message follows Conventional Commits format
#
# Installation:
#   cp .githooks/commit-msg .git/hooks/commit-msg
#   chmod +x .git/hooks/commit-msg

commit_msg=$(cat "$1")

# Skip merge commits and revert commits
if echo "$commit_msg" | grep -qE "^Merge|^Revert|^fixup!|^squash!"; then
    exit 0
fi

# Validate Conventional Commits format
if ! echo "$commit_msg" | grep -qE "^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert|security|deprecate)(\([a-zA-Z0-9_-]+\))?: .+"; then
    echo ""
    echo "❌ Commit message does not follow Conventional Commits format"
    echo ""
    echo "Format: <type>(<scope>): <description>"
    echo ""
    echo "Available types:"
    echo "  feat       - New feature"
    echo "  fix        - Bug fix"
    echo "  docs       - Documentation changes"
    echo "  style      - Code style (no functional changes)"
    echo "  refactor   - Code refactoring"
    echo "  perf       - Performance improvements"
    echo "  test       - Test-related changes"
    echo "  build      - Build system changes"
    echo "  ci         - CI/CD changes"
    echo "  chore      - Other changes"
    echo "  revert     - Revert previous commits"
    echo "  security   - Security fixes"
    echo "  deprecate  - Deprecate features"
    echo ""
    echo "Examples:"
    echo "  feat(llm): add OpenAI provider support"
    echo "  fix(mcp): resolve connection leak"
    echo "  docs: update README"
    echo ""
    echo "See: https://www.conventionalcommits.org/"
    echo ""
    exit 1
fi

echo "✅ Commit message format valid"
exit 0
