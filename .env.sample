# ============================================================
# GitHub Insight Agent - Environment Configuration Template
# ============================================================
# Copy this file to ~/.env (global) or .env (project root)
# and fill in your actual values. Do NOT commit the real .env file.
#
# cp .env.sample ~/.env
# ============================================================

# --- Model API Keys ---
# GIA model API key (DashScope / Alibaba Cloud Bailian)
GIA_DASHSCOPE_API_KEY=YOUR_GIA_DASHSCOPE_API_KEY_HERE

# Shared DashScope base URL (coding endpoint / model endpoint)
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Claude Code model API key (separate from GIA, if using DashScope for coding)
DASHSCOPE_API_KEY=YOUR_DASHSCOPE_API_KEY_HERE

# --- GitHub ---
# GitHub Personal Access Token (repo scope)
GITHUB_TOKEN=YOUR_GITHUB_TOKEN_HERE

# --- Notification Channels (optional) ---
# WeChat notification channel ID
WECHAT_CHANNEL_ID=YOUR_WECHAT_CHANNEL_ID_HERE

# Feishu/Lark notification group ID
FEISHU_GROUP_ID=YOUR_FEISHU_GROUP_ID_HERE
