# ===========================================
# GitHub Insight Agent - 环境变量模板
# ===========================================
# 复制此文件为 .env 并填入真实值
# 注意：.env 文件已被 .gitignore 排除，不要上传到 Git
#
# 全局配置（API Keys、群组 ID 等）位于：/home/lisa/.env
# 本项目仅需填写下方项目特定配置
# ===========================================

# ===========================================
# 项目特定模型配置
# ===========================================
DASHSCOPE_ORGANIZATION_ID=YourOrganizationName
DASHSCOPE_MODEL_NAME=qwen3.5-plus

# ===========================================
# GitHub API 配置（如不使用全局配置则填写）
# ===========================================
GITHUB_API_URL=https://api.github.com
GITHUB_TIMEOUT=30
GITHUB_RATE_LIMIT=10

# ===========================================
# 日志配置
# ===========================================
LOG_LEVEL=INFO
LOG_MAX_SIZE_MB=10
LOG_RETENTION_DAYS=7
LOG_DIR=logs

# ===========================================
# AgentScope 配置
# ===========================================
AGENTSCOPE_PROJECT=GitHub Insight Agent
AGENTSCOPE_RUN_NAME=main
AGENTSCOPE_ENABLE_STUDIO=true
AGENTSCOPE_STUDIO_URL=http://localhost:3000

# ===========================================
# 应用配置
# ===========================================
PROJECT_ROOT=/home/lisa/claude_apps/github-insight-agent
CONFIG_DIR=configs
MODEL_CONFIG_FILE=model_configs.json
PROMPT_TEMPLATES_DIR=prompt_templates
OUTPUT_DIR=output
TEMP_DIR=tmp

# ===========================================
# 高级配置
# ===========================================
MAX_RETRIES=3
RETRY_DELAY_SECONDS=1
RETRY_BACKOFF_MULTIPLIER=2.0
REQUEST_TIMEOUT=60
DEBUG_MODE=false
